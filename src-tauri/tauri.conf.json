{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Winmux",
  "version": "0.1.0",
  "identifier": "com.winmux.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Winmux",
        "width": 1200,
        "height": 760,
        "minWidth": 760,
        "minHeight": 480,
        "decorations": false,
        "shadow": true,
        "backgroundColor": "#0a0d12"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
